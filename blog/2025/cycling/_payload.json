[{"data":1,"prerenderedAt":496},["ShallowReactive",2],{"content-query-W3ZnM12csC":3},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"date":10,"readtime":11,"tags":12,"body":19,"_type":490,"_id":491,"_source":492,"_file":493,"_stem":494,"_extension":495},"/blog/2025/cycling","2025",false,"","Cycling 80km in the Netherlands 🚴‍♂️","Data-driven exploration of my longest cycling ride yet","2025-02-20","4",{"language":13,"field":14,"type":16},[],[15],"data visualisation",[17,18],"mental health","sports",{"type":20,"children":21,"toc":475},"root",[22,31,68,80,86,102,111,118,125,130,237,243,248,253,282,311,317,322,345,351,356,379,385,390,395,403,409],{"type":23,"tag":24,"props":25,"children":27},"element","h2",{"id":26},"preface",[28],{"type":29,"value":30},"text","Preface",{"type":23,"tag":32,"props":33,"children":34},"p",{},[35,37,43,45,50,52,66],{"type":29,"value":36},"I have been living in the Netherlands since September 2018. In the blink of an eye, I graduated, got my first job, switched careers, and in the midst of it, a whole pandemic occurred. Safe to say that these last 6.5 years felt like they flew by. When people think about the Netherlands, one of the first things that comes to mind is, you guessed it, ",{"type":23,"tag":38,"props":39,"children":40},"strong",{},[41],{"type":29,"value":42},"bikes",{"type":29,"value":44},"! According to the ",{"type":23,"tag":38,"props":46,"children":47},{},[48],{"type":29,"value":49},"Netherlands Institute for Transport Policy Analysis",{"type":29,"value":51}," (KiM), in 2022, there were an estimated 23.9 million",{"type":23,"tag":53,"props":54,"children":55},"sup",{},[56],{"type":23,"tag":57,"props":58,"children":63},"a",{"href":59,"ariaDescribedBy":60,"dataFootnoteRef":7,"id":62},"#user-content-fn-1",[61],"footnote-label","user-content-fnref-1",[64],{"type":29,"value":65},"1",{"type":29,"value":67}," bicycles, amounting to about 1.3 bicycles per person. That's a whole lot of bikes.",{"type":23,"tag":32,"props":69,"children":70},{},[71,73,78],{"type":29,"value":72},"Personally, I enjoy cycling quite a bit. Not only because it's great for overall fitness, but also because of its effect on my mental health. Over nine months ago (May 9, 2024), I decided to go on a long distance cycling ride, partly motivated by the blooming flower fields, but also just because I enjoy it. I ended up cycling over a distance of 80km, starting at home, in Amsterdam, going around 35km South, to Lisse, a little town close to the famous flower fields of ",{"type":23,"tag":38,"props":74,"children":75},{},[76],{"type":29,"value":77},"Keukenhof",{"type":29,"value":79},", and then all the way back home. In this blog post, I want to take you together with me on this ride and share some nerdy insights and moments.",{"type":23,"tag":24,"props":81,"children":83},{"id":82},"cycling-route",[84],{"type":29,"value":85},"Cycling route",{"type":23,"tag":32,"props":87,"children":88},{},[89,91,100],{"type":29,"value":90},"As you would expect, the Netherlands has excellent cycling infrastructure with approximately 153,000km",{"type":23,"tag":53,"props":92,"children":93},{},[94],{"type":23,"tag":57,"props":95,"children":98},{"href":59,"ariaDescribedBy":96,"dataFootnoteRef":7,"id":97},[61],"user-content-fnref-1-2",[99],{"type":29,"value":65},{"type":29,"value":101}," of cycle paths. So it's not difficult to imagine that you can pretty much get anywhere by bike in this country. I didn't have a very strict plan or route in mind, my sole goal was to bike a considerable distance and see the flower fields. Below you can find the whole trip with markers at every 10km.",{"type":23,"tag":32,"props":103,"children":104},{},[105],{"type":23,"tag":106,"props":107,"children":110},"img",{"alt":108,"src":109},"route","images/2025/12.cycling/route.png",[],{"type":23,"tag":32,"props":112,"children":115},{"className":113},[114],"figure-caption",[116],{"type":29,"value":117},"Cycling route (May 9, 2024).",{"type":23,"tag":119,"props":120,"children":122},"h3",{"id":121},"statistics",[123],{"type":29,"value":124},"Statistics",{"type":23,"tag":32,"props":126,"children":127},{},[128],{"type":29,"value":129},"Here are some basic statistics on speed (km/h) and elevation (m) for this trip.",{"type":23,"tag":131,"props":132,"children":133},"table",{},[134,154],{"type":23,"tag":135,"props":136,"children":137},"thead",{},[138],{"type":23,"tag":139,"props":140,"children":141},"tr",{},[142,149],{"type":23,"tag":143,"props":144,"children":146},"th",{"align":145},"center",[147],{"type":29,"value":148},"Metric",{"type":23,"tag":143,"props":150,"children":151},{"align":145},[152],{"type":29,"value":153},"Value",{"type":23,"tag":155,"props":156,"children":157},"tbody",{},[158,172,185,198,211,224],{"type":23,"tag":139,"props":159,"children":160},{},[161,167],{"type":23,"tag":162,"props":163,"children":164},"td",{"align":145},[165],{"type":29,"value":166},"Minimum speed",{"type":23,"tag":162,"props":168,"children":169},{"align":145},[170],{"type":29,"value":171},"0.01",{"type":23,"tag":139,"props":173,"children":174},{},[175,180],{"type":23,"tag":162,"props":176,"children":177},{"align":145},[178],{"type":29,"value":179},"Maximum speed",{"type":23,"tag":162,"props":181,"children":182},{"align":145},[183],{"type":29,"value":184},"30.63",{"type":23,"tag":139,"props":186,"children":187},{},[188,193],{"type":23,"tag":162,"props":189,"children":190},{"align":145},[191],{"type":29,"value":192},"Median speed",{"type":23,"tag":162,"props":194,"children":195},{"align":145},[196],{"type":29,"value":197},"18.2",{"type":23,"tag":139,"props":199,"children":200},{},[201,206],{"type":23,"tag":162,"props":202,"children":203},{"align":145},[204],{"type":29,"value":205},"Mean speed",{"type":23,"tag":162,"props":207,"children":208},{"align":145},[209],{"type":29,"value":210},"16.91",{"type":23,"tag":139,"props":212,"children":213},{},[214,219],{"type":23,"tag":162,"props":215,"children":216},{"align":145},[217],{"type":29,"value":218},"Minimum elevation",{"type":23,"tag":162,"props":220,"children":221},{"align":145},[222],{"type":29,"value":223},"-5.02",{"type":23,"tag":139,"props":225,"children":226},{},[227,232],{"type":23,"tag":162,"props":228,"children":229},{"align":145},[230],{"type":29,"value":231},"Maximum elevation",{"type":23,"tag":162,"props":233,"children":234},{"align":145},[235],{"type":29,"value":236},"6.34",{"type":23,"tag":119,"props":238,"children":240},{"id":239},"speed",[241],{"type":29,"value":242},"Speed",{"type":23,"tag":32,"props":244,"children":245},{},[246],{"type":29,"value":247},"If there's one thing I learned with this experience, it's that long distance cycling rides are tiring (who would have thought?). If you're a beginner, make sure to get some rest every other hour, bring plenty of water, a source of energy (e.g. protein bars), and be sure to also bring a power bank with you lest you get lost in the wilderness and can't find your way back.",{"type":23,"tag":32,"props":249,"children":250},{},[251],{"type":29,"value":252},"My median speed was 18.2 km/h. For me, that was a maintainable speed for this type of long distance ride. I pushed it all the way up to 30.63 km/h at some point because I really wanted to know how fast I could bike with my 75€ rusty student bike (yep, still alive and kicking). It was fun, but it's not a bike that is really meant for this type of trip, more of a city bike.",{"type":23,"tag":254,"props":255,"children":256},"div",{},[257,259,275,276],{"type":29,"value":258},"\n  ",{"type":23,"tag":260,"props":261,"children":263},"figure",{"className":262},[260],[264,266,274],{"type":29,"value":265},"\n    ",{"type":23,"tag":106,"props":267,"children":273},{"alt":268,"src":269,"className":270},"Speed plot","/images/2025/12.cycling/speed.svg",[271,272],"figure-image","svg",[],{"type":29,"value":258},{"type":29,"value":258},{"type":23,"tag":32,"props":277,"children":279},{"className":278},[114],[280],{"type":29,"value":281},"Speed plot.",{"type":23,"tag":283,"props":284,"children":285},"blockquote",{},[286],{"type":23,"tag":32,"props":287,"children":288},{},[289,291,296,298,309],{"type":29,"value":290},"🗒️ ",{"type":23,"tag":38,"props":292,"children":293},{},[294],{"type":29,"value":295},"Note",{"type":29,"value":297},": All plots have been averaged per minute, so you won't be able to see the entirety of the data, particularly isolated peaks. I'm using SVG",{"type":23,"tag":53,"props":299,"children":300},{},[301],{"type":23,"tag":57,"props":302,"children":306},{"href":303,"ariaDescribedBy":304,"dataFootnoteRef":7,"id":305},"#user-content-fn-2",[61],"user-content-fnref-2",[307],{"type":29,"value":308},"2",{"type":29,"value":310}," files to display the data. There are 17081 data points for this ride. This significantly slows the rendering of the page. Thus, I averaged the data per minute, yielding a total of 289 data points.",{"type":23,"tag":119,"props":312,"children":314},{"id":313},"elevation",[315],{"type":29,"value":316},"Elevation",{"type":23,"tag":32,"props":318,"children":319},{},[320],{"type":29,"value":321},"In terms of elevation, the ride was relatively flat, as expected in the Netherlands. The minimum elevation of -5.02m below sea level and the maximum elevation of 6.34m show that there were only minor changes in altitude, mainly due to bridges and viaducts. This made the ride less physically demanding and more enjoyable.",{"type":23,"tag":254,"props":323,"children":324},{},[325,326,338,339],{"type":29,"value":258},{"type":23,"tag":260,"props":327,"children":329},{"className":328},[260],[330,331,337],{"type":29,"value":265},{"type":23,"tag":106,"props":332,"children":336},{"alt":333,"src":334,"className":335},"Elevation plot","/images/2025/12.cycling/elevation.svg",[271,272],[],{"type":29,"value":258},{"type":29,"value":258},{"type":23,"tag":32,"props":340,"children":342},{"className":341},[114],[343],{"type":29,"value":344},"Elevation plot.",{"type":23,"tag":119,"props":346,"children":348},{"id":347},"distance",[349],{"type":29,"value":350},"Distance",{"type":23,"tag":32,"props":352,"children":353},{},[354],{"type":29,"value":355},"Lastly, let's take a look at the cumulative distance. It's interesting to see that, with the exception of the one longer pause I took close to the middle of the trip, the distance I rode with my bike was virtually linear. This is somewhat peculiar as I would have guessed that, with the passing hours, one would tire and the speed at which you would ride a bike would slowly decreasing, and this would be reflected in this plot, perhaps best represented by a logarithmic trendline.",{"type":23,"tag":254,"props":357,"children":358},{},[359,360,372,373],{"type":29,"value":258},{"type":23,"tag":260,"props":361,"children":363},{"className":362},[260],[364,365,371],{"type":29,"value":265},{"type":23,"tag":106,"props":366,"children":370},{"alt":367,"src":368,"className":369},"Distance plot","/images/2025/12.cycling/distance.svg",[271,272],[],{"type":29,"value":258},{"type":29,"value":258},{"type":23,"tag":32,"props":374,"children":376},{"className":375},[114],[377],{"type":29,"value":378},"Distance plot.",{"type":23,"tag":24,"props":380,"children":382},{"id":381},"outro",[383],{"type":29,"value":384},"Outro",{"type":23,"tag":32,"props":386,"children":387},{},[388],{"type":29,"value":389},"This was a great experience that I would highly recommend to anyone who enjoys cycling or is looking for a way to explore a less conventional way to uplift their spirits. The combination of physical activity, scenery, and the sense of accomplishment from completing such a long ride made it a memorable adventure. Whether you're a seasoned cyclist or a beginner, there's something rewarding about pushing your limits and discovering new places on two wheels. So, grab your bike, plan your route, and embark on your own cycling journey. Here are a few shots from my trip 😊",{"type":23,"tag":32,"props":391,"children":392},{},[393],{"type":29,"value":394},"I'm planning to do another cycling trip this year once the weather clears up a bit, this time around I'm aiming for 100km! 🚴‍♂️",{"type":23,"tag":32,"props":396,"children":397},{},[398],{"type":23,"tag":106,"props":399,"children":402},{"alt":400,"src":401},"trip","images/2025/12.cycling/trip.png",[],{"type":23,"tag":32,"props":404,"children":406},{"className":405},[114],[407],{"type":29,"value":408},"A few shots from my trip.",{"type":23,"tag":410,"props":411,"children":414},"section",{"className":412,"dataFootnotes":7},[413],"footnotes",[415,422],{"type":23,"tag":24,"props":416,"children":419},{"className":417,"id":61},[418],"sr-only",[420],{"type":29,"value":421},"Footnotes",{"type":23,"tag":423,"props":424,"children":425},"ol",{},[426,462],{"type":23,"tag":427,"props":428,"children":430},"li",{"id":429},"user-content-fn-1",[431,439,441,450,451],{"type":23,"tag":57,"props":432,"children":436},{"href":433,"rel":434},"https://english.kimnet.nl/binaries/kimnet-english/documenten/publications/2024/01/10/cycling-facts-2023/KiM+brochure+Cycling+facts+2023_def.pdf",[435],"nofollow",[437],{"type":29,"value":438},"Cycling facts 2023",{"type":29,"value":440}," ",{"type":23,"tag":57,"props":442,"children":447},{"href":443,"ariaLabel":444,"className":445,"dataFootnoteBackref":7},"#user-content-fnref-1","Back to reference 1",[446],"data-footnote-backref",[448],{"type":29,"value":449},"↩",{"type":29,"value":440},{"type":23,"tag":57,"props":452,"children":456},{"href":453,"ariaLabel":454,"className":455,"dataFootnoteBackref":7},"#user-content-fnref-1-2","Back to reference 1-2",[446],[457,458],{"type":29,"value":449},{"type":23,"tag":53,"props":459,"children":460},{},[461],{"type":29,"value":308},{"type":23,"tag":427,"props":463,"children":465},{"id":464},"user-content-fn-2",[466,468],{"type":29,"value":467},"Scalable Vector Graphics ",{"type":23,"tag":57,"props":469,"children":473},{"href":470,"ariaLabel":471,"className":472,"dataFootnoteBackref":7},"#user-content-fnref-2","Back to reference 2",[446],[474],{"type":29,"value":449},{"title":476,"searchDepth":477,"depth":478,"links":479},"Table of Contents",3,5,[480,482,488,489],{"id":26,"depth":481,"text":30},2,{"id":82,"depth":481,"text":85,"children":483},[484,485,486,487],{"id":121,"depth":477,"text":124},{"id":239,"depth":477,"text":242},{"id":313,"depth":477,"text":316},{"id":347,"depth":477,"text":350},{"id":381,"depth":481,"text":384},{"id":61,"depth":481,"text":421},"markdown","content:blog:2025:12.cycling.md","content","blog/2025/12.cycling.md","blog/2025/12.cycling","md",1741792045850]