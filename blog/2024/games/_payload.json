":1269},[],[1271],{"type":29,"value":1272},"platforms.name",{"type":29,"value":1274},": video game platforms (e.g. \"PlayStation 5\")",{"type":23,"tag":337,"props":1276,"children":1277},{},[1278,1284],{"type":23,"tag":134,"props":1279,"children":1281},{"className":1280},[],[1282],{"type":29,"value":1283},"rating",{"type":29,"value":1285},": average IGDB user rating",{"type":23,"tag":337,"props":1287,"children":1288},{},[1289,1295],{"type":23,"tag":134,"props":1290,"children":1292},{"className":1291},[],[1293],{"type":29,"value":1294},"url",{"type":29,"value":1296},": IGDB video game URL",{"type":23,"tag":32,"props":1298,"children":1299},{},[1300,1302,1309],{"type":29,"value":1301},"Feel free to explore more fields provisioned by the IGDB API in the ",{"type":23,"tag":38,"props":1303,"children":1306},{"href":1304,"rel":1305},"https://api-docs.igdb.com/#game",[76],[1307],{"type":29,"value":1308},"docs",{"type":29,"value":1310},".",{"type":23,"tag":32,"props":1312,"children":1313},{},[1314],{"type":29,"value":1315},"On top of these fields, we also filter the results on the following points:",{"type":23,"tag":333,"props":1317,"children":1318},{},[1319,1330,1341],{"type":23,"tag":337,"props":1320,"children":1321},{},[1322,1328],{"type":23,"tag":134,"props":1323,"children":1325},{"className":1324},[],[1326],{"type":29,"value":1327},"category = 0",{"type":29,"value":1329},": only include the main game (e.g. no DLCs)",{"type":23,"tag":337,"props":1331,"children":1332},{},[1333,1339],{"type":23,"tag":134,"props":1334,"children":1336},{"className":1335},[],[1337],{"type":29,"value":1338},"version_parent = null",{"type":29,"value":1340},": exclude game versions (e.g. \"Deluxe Edition\")",{"type":23,"tag":337,"props":1342,"children":1343},{},[1344,1350],{"type":23,"tag":134,"props":1345,"children":1347},{"className":1346},[],[1348],{"type":29,"value":1349},"limit 5",{"type":29,"value":1351},": restrict results to a maximum of five entries",{"type":23,"tag":32,"props":1353,"children":1354},{},[1355,1357,1363,1365,1370],{"type":29,"value":1356},"Once the query is set, we make the actual POST request using ",{"type":23,"tag":134,"props":1358,"children":1360},{"className":1359},[],[1361],{"type":29,"value":1362},"requests.post",{"type":29,"value":1364},", making sure to include the ",{"type":23,"tag":134,"props":1366,"children":1368},{"className":1367},[],[1369],{"type":29,"value":1187},{"type":29,"value":1371}," to allow us to authenticate successfully. The results are then parsed to JSON format so that we can process it further.",{"type":23,"tag":116,"props":1373,"children":1375},{"id":1374},"creating-a-table",[1376],{"type":29,"value":1377},"Creating a table",{"type":23,"tag":32,"props":1379,"children":1380},{},[1381,1383,1389,1391,1397,1399,1405],{"type":29,"value":1382},"Some trivial data post-processing is performed on the results such as converting Unix timestamps to human-readable format and extracting only the year, rounding the IGDB average rating to 1 decimal case, sorting the genres alphabetically, among others. I also kept track of games that failed being parsed (e.g. not present in the database, wrong name, etc.). Once all is set and done, I created a ",{"type":23,"tag":134,"props":1384,"children":1386},{"className":1385},[],[1387],{"type":29,"value":1388},"polars.DataFrame",{"type":29,"value":1390}," and generated a CSV file using the ",{"type":23,"tag":134,"props":1392,"children":1394},{"className":1393},[],[1395],{"type":29,"value":1396},"write_csv",{"type":29,"value":1398}," method from the ",{"type":23,"tag":134,"props":1400,"children":1402},{"className":1401},[],[1403],{"type":29,"value":1404},"DataFrame",{"type":29,"value":1406}," class. That's it! 🎉",{"type":23,"tag":32,"props":1408,"children":1409},{},[1410],{"type":29,"value":1411},"Here's what the output CSV file looks like:",{"type":23,"tag":1413,"props":1414,"children":1415},"table",{},[1416,1456],{"type":23,"tag":1417,"props":1418,"children":1419},"thead",{},[1420]