ppflowy",{"type":29,"value":1585}," - in a nusthell, a FOSS",{"type":23,"tag":83,"props":1587,"children":1588},{},[1589],{"type":23,"tag":38,"props":1590,"children":1594},{"href":1591,"ariaDescribedBy":1592,"dataFootnoteRef":7,"id":1593},"#user-content-fn-4",[90],"user-content-fnref-4",[1595],{"type":29,"value":1596},"4",{"type":29,"value":1598}," replacement for well-established note-taking apps such as Notion and Obsidian.",{"type":23,"tag":24,"props":1600,"children":1602},{"id":1601},"outro",[1603],{"type":29,"value":1604},"Outro",{"type":23,"tag":32,"props":1606,"children":1607},{},[1608,1610,1615],{"type":29,"value":1609},"This was a fun little project, easy to come up with and also an excuse to try out new tools (such as ",{"type":23,"tag":134,"props":1611,"children":1613},{"className":1612},[],[1614],{"type":29,"value":127},{"type":29,"value":1616},"). Maybe I can use this ordered data to create some kind of recommendation system, or integrate it with my own reviews and display that somewhere online for archival purposes.",{"type":23,"tag":1618,"props":1619,"children":1622},"section",{"className":1620,"dataFootnotes":7},[1621],"footnotes",[1623,1630],{"type":23,"tag":24,"props":1624,"children":1627},{"className":1625,"id":90},[1626],"sr-only",[1628],{"type":29,"value":1629},"Footnotes",{"type":23,"tag":1631,"props":1632,"children":1633},"ol",{},[1634,1656,1669,1688],{"type":23,"tag":337,"props":1635,"children":1637},{"id":1636},"user-content-fn-1",[1638,1645,1647],{"type":23,"tag":38,"props":1639,"children":1642},{"href":1640,"rel":1641},"https://en.wikipedia.org/wiki/IGDB",[76],[1643],{"type":29,"value":1644},"Wikipedia - IGDB",{"type":29,"value":1646}," ",{"type":23,"tag":38,"props":1648,"children":1653},{"href":1649,"ariaLabel":1650,"className":1651,"dataFootnoteBackref":7},"#user-content-fnref-1","Back to reference 1",[1652],"data-footnote-backref",[1654],{"type":29,"value":1655},"↩",{"type":23,"tag":337,"props":1657,"children":1659},{"id":1658},"user-con