ype":29,"value":584},{"type":29,"value":604}," is a unique identifier for the client and comes with a ",{"type":23,"tag":134,"props":606,"children":608},{"className":607},[],[609],{"type":29,"value":593},{"type":29,"value":611}," that the user can generate using their Twitch account (IGDB is owned by Twitch, which is itself owned by Amazon). Both of these variables are confidential and should be kept away from prying eyes, as they will be used to request an ",{"type":23,"tag":134,"props":613,"children":615},{"className":614},[],[616],{"type":29,"value":617},"access_token",{"type":29,"value":619}," from the IGDB API which will then be used for authentication.",{"type":23,"tag":32,"props":621,"children":622},{},[623,625,631],{"type":29,"value":624},"One proven way to store sensitive information like the one described above is to store these values in a local ",{"type":23,"tag":134,"props":626,"children":628},{"className":627},[],[629],{"type":29,"value":630},".env",{"type":29,"value":632}," file.",{"type":23,"tag":634,"props":635,"children":636},"blockquote",{},[637],{"type":23,"tag":32,"props":638,"children":639},{},[640,642,647,649,654,656,667],{"type":29,"value":641},"⚠️ ",{"type":23,"tag":123,"props":643,"children":644},{},[645],{"type":29,"value":646},"Warning",{"type":29,"value":648},": never ever push ",{"type":23,"tag":134,"props":650,"children":652},{"className":651},[],[653],{"type":29,"value":630},{"type":29,"value":655}," files or similar secret-containing files to any VCS",{"type":23,"tag":83,"props":657,"children":658},{},[659],{"type":23,"tag":38,"props":660,"children":664},{"href":661,"ariaDescribedBy":662,"dataFootnoteRef":7,"id":663},"#user-content-fn-2",[90],"user-content-fnref-2",[665],{"type":29,"value":666},"2",{"type":29,"value":668},"!",{"type":23,"tag":32,"props":670,"children":671},{},[672,674,679,681,686],{"type":29,"value":673},"In Python, the ",{"type":23,"tag":134,"props":675,"children":677},{"className":676},[],[678],{"type":29,"value":3